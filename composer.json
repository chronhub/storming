{
  "name": "chronhub/storming",
  "description": "foundation",
  "keywords": ["foundation"],
  "license": "MIT",
  "authors": [
    {
      "name": "steph bug",
      "email": "chronhubgit@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "psr/container": "dev-master",
    "react/react": "^1.3",
    "symfony/uid": "6.3.x",
    "symfony/clock": "^6.4",
    "symfony/serializer": "^6.4",
    "composer-runtime-api": "^2.2"
  },
  "replace": {
    "chronhub/contract": "self.version",
    "chronhub/stream": "self.version",
    "chronhub/tracker": "self.version",
    "chronhub/message": "self.version",
    "chronhub/chronicler": "self.version"
  },
  "require-dev": {
    "ext-pcntl": "*",
    "ext-posix": "*",
    "laravel/pint": "^v1.1",
    "pestphp/pest": "2.x-dev",
    "pestphp/pest-plugin-type-coverage": "2.x-dev",
    "nunomaduro/larastan": "^2.6",
    "nunomaduro/phpinsights": "dev-master",
    "orchestra/testbench": "^8.x-dev",
    "phpstan/phpstan": "^1.10.x-dev",
    "phpunit/phpunit": "^10.3",
    "rector/rector": "dev-main",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Storm\\": "src/Storm/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Storm\\Tests\\": "tests"
    },
    "files": [
      "./tests/functions.php"
    ]
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "pint": "vendor/bin/pint",
    "rector-init": "vendor/bin/rector init",
    "rector-dry": "vendor/bin/rector process --dry-run",
    "rector-process": "vendor/bin/rector process"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev"
}
